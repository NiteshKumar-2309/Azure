# Azure Service Bus shared connection string (no quotes)
SERVICE_BUS_CONNECTION_STR=Endpoint=sb://<your-namespace>.servicebus.windows.net/;SharedAccessKeyName=<key-name>;SharedAccessKey=<key-value>

# Queue name used by queuesTest.py and queuesReceiverTest.py
SERVICE_BUS_QUEUE_NAME=<your-queue-name>

# Topic name used by subsProducerTest.py and subsReceiverTest.py
SERVICE_BUS_TOPIC_NAME=<your-topic-name>

# Comma-separated list of subscriptions for subsReceiverTest.py
# Example: subscription_2,subscription_1
SERVICE_BUS_SUBSCRIPTIONS=<subscription_1,subscription_2>
