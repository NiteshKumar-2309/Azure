# Azure Storage
# Connection string for your Azure Storage Account
stellar07042026_STORAGE=DefaultEndpointsProtocol=https;AccountName=your_account_name;AccountKey=your_account_key;EndpointSuffix=core.windows.net

# Azure Document Intelligence
# Your Document Intelligence service endpoint and key
DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com/
DOCUMENT_INTELLIGENCE_KEY=your_document_intelligence_key_here

# Azure Content Understanding
# Your Content Understanding service endpoint, key, and analyzer ID
CU_ENDPOINT=https://your-cu-endpoint.cognitiveservices.azure.com/
CU_KEY=your_content_understanding_key_here
CU_ANALYZER_ID=your_analyzer_id_here

# Azure Cosmos DB
# Connection string, database name, and container name for Cosmos DB
COSMOS_CONNECTION_STRING=AccountEndpoint=https://your-cosmos-account.documents.azure.com:443/;AccountKey=your_cosmos_key;
COSMOS_DATABASE_NAME=your_database_name_here
COSMOS_CONTAINER_NAME=your_container_name_here

# Redis Cache
# Azure Redis Cache connection details
REDIS_HOST=your-redis-instance.redis.azure.net
REDIS_PORT=6380
REDIS_PASSWORD=your_redis_password_here
REDIS_SSL=True
REDIS_SOCKET_TIMEOUT=5

